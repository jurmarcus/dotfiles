# Taps (must be first)
tap "oven-sh/bun"

# Version Control
brew "git"
brew "sapling"
brew "gh"           # GitHub CLI

# Editors
brew "neovim"
cask "vscodium"
cask "zed"

# Runtimes & Package Managers
brew "uv"           # Python
brew "oven-sh/bun/bun"  # TypeScript/JavaScript
brew "rustup"       # Rust (includes cargo, clippy via: rustup component add clippy rustfmt)
cask "temurin@21"   # Java (for Android builds)

# Linting & Formatting
brew "ruff"         # Python
brew "biome"        # JS/TS

# Build Tools
brew "watchexec"    # file watcher
brew "watchman"     # Meta's file watcher (used by sapling ISL for live refresh)
brew "just"         # modern make (task runner)

# iOS/macOS
brew "cocoapods"    # dependency manager

# Android (added with apps/jisho-android scaffold)
cask "android-commandlinetools"   # sdkmanager + avdmanager
cask "android-platform-tools"     # adb + fastboot, brew-managed
brew "gradle"                     # one-time wrapper bootstrap; wrapper used thereafter
brew "scrcpy"                     # screen mirror — emu/Tailscale device → mac window
# cask "android-studio"           # optional; uncomment if hybrid IDE workflow desired
